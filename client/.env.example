# Backend API base URL (no trailing slash). The NestJS server prefixes all
# routes with /api, so include the prefix here. For local dev this is the
# default. In Amplify, set this to your deployed backend (e.g. App Runner,
# Elastic Beanstalk, ECS Fargate) URL plus /api.
VITE_API_URL="http://localhost:3000/api"

# Auth0
VITE_AUTH0_DOMAIN="your-domain.auth0.com"
VITE_AUTH0_CLIENT_ID="your-client-id"
VITE_AUTH0_AUDIENCE="your-api-audience"
